# -----------------------------------------------------------------------------
# PAWBOOK ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to a new file named `.env` and fill in your credentials.
# -----------------------------------------------------------------------------

# NEXTAUTH SETUP
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=pawbook-nextauth-secret-key-321-go
NEXTAUTH_URL=https://www.bitpawos.com

# CLOUDINARY STORAGE CONFIGURATION
# Find these keys in your Cloudinary Dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# DATABASE PATH (Optional override, default is file:./dev.db in SQLite)
# DATABASE_URL=file:./dev.db

# WEBHOOK SECURITY KEYS
CRAWLER_KEY=pawbook-crawler-secret-key-123

# TURSO CLOUD DATABASE CONFIGURATION (For Vercel deployment)
# TURSO_DATABASE_URL=libsql://your-db-name-username.turso.io
# TURSO_AUTH_TOKEN=your_auth_token_here

# ZEGOCLOUD INTEGRATION FOR VIDEO CALLS
NEXT_PUBLIC_ZEGO_APP_ID=your_zegocloud_app_id_here
NEXT_PUBLIC_ZEGO_SERVER_SECRET=your_zegocloud_server_secret_here
